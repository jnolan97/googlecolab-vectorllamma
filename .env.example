# PXE Server Configuration
# Network Configuration
DHCP_SUBNET=${DHCP_SUBNET:-192.168.1.0}
DHCP_NETMASK=${DHCP_NETMASK:-255.255.255.0}
DHCP_RANGE_START=${DHCP_RANGE_START:-192.168.1.100}
DHCP_RANGE_END=${DHCP_RANGE_END:-192.168.1.200}
DHCP_GATEWAY=${DHCP_GATEWAY:-192.168.1.1}
DHCP_DNS=${DHCP_DNS:-8.8.8.8,8.8.4.4}

# PXE Server Configuration
PXE_SERVER_IP=${PXE_SERVER_IP:-192.168.1.10}
TFTP_ROOT=${TFTP_ROOT:-/var/lib/tftpboot}
NFS_ROOT=${NFS_ROOT:-/var/lib/nfs}
DHCP_LEASE_TIME=${DHCP_LEASE_TIME:-7200}

# Service Configuration
DHCP_INTERFACE=${DHCP_INTERFACE:-eth0}
TFTP_PORT=${TFTP_PORT:-69}
NFS_PORT=${NFS_PORT:-2049}

# Security Configuration
ALLOW_BOOTP=${ALLOW_BOOTP:-true}
SECURE_TFTP=${SECURE_TFTP:-false}
NFS_SECURITY=${NFS_SECURITY:-sys}

# File Paths
DHCP_CONFIG_FILE=${DHCP_CONFIG_FILE:-/etc/dhcp/dhcpd.conf}
TFTP_CONFIG_FILE=${TFTP_CONFIG_FILE:-/etc/default/tftpd-hpa}
NFS_CONFIG_FILE=${NFS_CONFIG_FILE:-/etc/exports}
PXELINUX_CONFIG_DIR=${PXELINUX_CONFIG_DIR:-/var/lib/tftpboot/pxelinux.cfg}

# Logging
LOG_LEVEL=${LOG_LEVEL:-INFO}
LOG_FILE=${LOG_FILE:-/var/log/pxe-server.log}